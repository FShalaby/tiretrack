# TireTrack local/demo environment
# Copy this file to .env and fill in the real values for that machine.

SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:mysql://localhost:3306/tiretrack
DB_USERNAME=root
DB_PASSWORD=replace-with-your-mysql-password

# Use a long random value. Plain text is supported; Base64 is also supported.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Platform owner bootstrap. This creates or repairs the software owner account.
PLATFORM_OWNER_BOOTSTRAP_ENABLED=true
PLATFORM_OWNER_EMAIL=fouad99877@gmail.com
PLATFORM_OWNER_NAME=Fouad Shalaby
PLATFORM_OWNER_PHONE=000-000-0000
PLATFORM_OWNER_PASSWORD=Amrouad99!
PLATFORM_OWNER_RESET_PASSWORD=false

# Local defaults
DDL_AUTO=validate
FLYWAY_ENABLED=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Keep maintenance jobs off unless intentionally running them.
APP_BACKFILL_ENABLED=false
APP_ACCOUNTING_BACKFILL_ENABLED=false
APP_AUDIT_LOG_MIGRATION_ENABLED=false
APP_PAYROLL_REPAIR_ENABLED=false
APP_ACCOUNT_VALIDATION_ENABLED=false
